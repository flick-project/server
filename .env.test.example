# -----------------------------------------------------------
# Environment variables for the test suite.
# Copy this file to .env.test and fill in the values.
# NOTE: Never push .env.test to the repository.
#
# Setup:
#   1. Start the test database: docker compose -f docker-compose.test.yml up -d
#   2. Run tests: npm test
#   3. Stop the test database: docker compose -f docker-compose.test.yml down
# -----------------------------------------------------------

# Test database (runs in Docker on port 5433 to avoid conflicts with dev)
DATABASE_URL=postgresql://flick:test@localhost:5433/flick_test

# Server
PORT=3000

# JWT (can use any value for testing)
JWT_SECRET=test-secret
JWT_LIFE=24h

# TMDB (not needed - tests mock TMDB calls)
TMDB_API_KEY=not-needed