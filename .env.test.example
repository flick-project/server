# -----------------------------------------------------------
# Environment variables for the test suite.
# Copy this file to .env.test and fill in the values.
# NOTE: Never push .env.test to the repository.
#
# Setup:
#   1. Create the test database: sudo -u postgres createdb flick_test
#   2. Copy the schema: sudo -u postgres pg_dump --schema-only flick | sudo -u postgres psql flick_test
# -----------------------------------------------------------

# Test database (must be separate from development)
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/flick_test

# Server
PORT=3001

# JWT (can use any value for testing)
JWT_SECRET=test-secret
JWT_LIFE=24h

# TMDB (not needed — tests mock TMDB calls)
TMDB_API_KEY=not-needed
