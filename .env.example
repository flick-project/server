# -----------------------------------------------------------
# Environment variables for flick-server.
# Copy this file to .env and fill in the values.
# NOTE: Never push .env to the repository.
# -----------------------------------------------------------

# Database
DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/flick

# Server
PORT=3000

# JWT
JWT_SECRET=
JWT_LIFE=24h

# TMDB
TMDB_API_KEY=
