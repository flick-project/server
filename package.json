{
  "name": "flick-server",
  "private": true,
  "version": "1.0.3",
  "description": "Backend API for Flick, built with Express and PostgreSQL.",
  "author": "Hans Nilsson",
  "license": "MIT",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node --env-file=.env src/server.js",
    "test": "node --env-file=.env.test --experimental-test-module-mocks --test --test-concurrency=1 tests/**/*.test.js",
    "test:unit": "node --env-file=.env.test --test tests/unit/**/*.test.js",
    "test:integration": "node --env-file=.env.test --experimental-test-module-mocks --test tests/integration/**/*.test.js",
    "lint": "npx eslint ./src || exit 0",
    "lint:fix": "npx eslint ./src --fix || exit 0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^62.9.0",
    "neostandard": "^0.13.0",
    "supertest": "^7.2.2"
  }
}
